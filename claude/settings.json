{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "95"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(export *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(jq *)",
      "Bash(sleep *)",
      "Bash(ps)",
      "Bash(ps *)",
      "Bash(chmod +x *)",
      "Bash(nvcc *)",
      "Bash(nvidia-smi)",
      "Bash(nvidia-smi *)",
      "Bash(curl *)",
      "Bash(git *)",
      "Bash(*python *)",
      "Bash(* *python *)",
      "Bash(uv *)",
      "Bash(* uv *)",
      "Bash(CUDA_VISIBLE_DEVICES=*)",
      "Bash(huggingface-cli *)",
      "Bash(bash /tmp/*)",
      "Bash(rm /tmp/*)",
      "Skill",
      "mcp__claude_ai_Notion__*",
      "mcp__claude_ai_Hugging_Face__*",
	  "mcp__claude_ai_Slack__*",
      "mcp__plugin_discord_discord__reply",
      "Bash(/home/oliver/.claude/scripts/ntfy-notify.sh *)"
    ],
    "deny": [
      "Bash(uv run python -c *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(* rm *)",
      "Bash(rm -rf *)",
      "Bash(chmod *)",
      "Bash(git -C *)",
      "Bash(git rm *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git push)",
      "Bash(git push *)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/tmp/",
      "/Users/oliverwang/agent_brain"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/fix-mcp-gate.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'count=$(find ~/agent_brain/00-inbox -name \"*.md\" -not -name \"_*\" 2>/dev/null | wc -l | tr -d \" \"); if [ \"$count\" -gt 0 ]; then echo \"{\\\"message\\\": \\\"Brain inbox: $count item(s) pending\\\"}\"; fi'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/claude-notify.sh 'Moshimoshi'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "astral@astral-sh": true,
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "discord@claude-plugins-official": true
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": true,
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "minimumVersion": "2.1.63",
  "voiceEnabled": true,
  "autoMemoryEnabled": true
}
