{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(for:*)",
      "Bash(do:*)",
      "Bash(done:*)",
      "Bash(chmod:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(export:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(sleep:*)",
      "Bash(ps:*)",
      "Bash(nvcc:*)",
      "Bash(nvidia-smi:*)",
      "Bash(curl:*)",
      "Bash(git:*)",
      "Bash(*uv *)",
      "Bash(*/home/oliver/.local/bin/uv *)",
      "mcp__claude_ai_Notion__*",
      "mcp__claude_ai_Hugging_Face*"
    ],
    "deny": [
      "Bash(git -C:*)",
      "Bash(*&&*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(git rm:*)",
      "Bash(git reset --hard)",
      "Bash(git push)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/tmp/"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/fix-mcp-gate.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/claude-notify.sh 'Moshimoshi'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "astral@astral-sh": true,
    "context7@claude-plugins-official": true
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": true,
  "autoUpdatesChannel": "latest",
  "autoMemoryEnabled": true
}
