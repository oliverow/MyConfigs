{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(for:*)",
      "Bash(do:*)",
      "Bash(done:*)",
      "Bash(chmod:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(export:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(sleep:*)",
      "Bash(ps:*)",
      "Bash(nvcc:*)",
      "Bash(nvidia-smi:*)",
      "Bash(curl:*)",
      "Bash(git:*)",
      "Bash(uv:*)",
      "Bash(/home/oliver/.local/bin/uv:*)",
      "Bash(*/home/oliver/.local/bin/uv run python *)",
      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__claude_ai_Notion__notion-update-page",
      "mcp__claude_ai_Notion__notion-create-pages",
      "mcp__claude_ai_Notion__notion-create-comment",
      "Bash(notify-send Claude Code:*)"
    ],
    "deny": [],
    "ask": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/fix-mcp-gate.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/claude-notify.sh 'Moshimoshi'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "astral@astral-sh": true,
    "context7@claude-plugins-official": true
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": true,
  "autoUpdatesChannel": "latest",
  "autoMemoryEnabled": true,
  "effortLevel": "medium"
}
